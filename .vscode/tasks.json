    {
      "label": "agentic-backend",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "if command -v lsof >/dev/null 2>&1; then pids=$(lsof -tiTCP:8000 -sTCP:LISTEN); if [ -n \"$pids\" ]; then kill $pids; fi; fi; make run PORT=8000"
      ],
      "options": { "cwd": "${workspaceFolder}/agentic-backend" },
      "problemMatcher": [],
      "presentation": { "panel": "new", "reveal": "always" }
    },
