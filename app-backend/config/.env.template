# app-backend startup contract (single-process mode)
# - Use one shared .env for embedded control-plane + agentic + knowledge-flow.
# - CONFIG_FILE must point to app-backend config profile.
#   Example:
#     CONFIG_FILE="./config/configuration.yaml"       # standalone/dev profile
#     CONFIG_FILE="./config/configuration_prod.yaml"  # local prod-like profile

CONFIG_FILE="./config/configuration.yaml"

# -----------------------------
# Catalog files (agentic)
# -----------------------------
# These 3 paths tell app-backend where agentic YAML catalogs live.
# In normal setup, keep them exactly as-is.
# Change them only if you intentionally use custom catalog files
# (for example a forked catalog folder) or if your repo layout changed.
# If unsure: do not change these values.
FRED_MODELS_CATALOG_FILE=../agentic-backend/config/models_catalog.yaml
FRED_AGENTS_CATALOG_FILE=../agentic-backend/config/agents_catalog.yaml
FRED_MCP_CATALOG_FILE=../agentic-backend/config/mcp_catalog.yaml

# -----------------------------
# Shared database / storage
# -----------------------------
FRED_POSTGRES_PASSWORD=
TABULAR_POSTGRES_PASSWORD=

MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=

# -----------------------------
# Keycloak / OpenFGA security
# -----------------------------
KEYCLOAK_CONTROL_PLANE_CLIENT_SECRET=
KEYCLOAK_KNOWLEDGE_FLOW_CLIENT_SECRET=
KEYCLOAK_AGENTIC_CLIENT_SECRET=
OPENFGA_API_TOKEN=

# -----------------------------
# LLM and observability
# -----------------------------
OPENAI_API_KEY=
OPENSEARCH_PASSWORD=

LANGFUSE_HOST=http://localhost:3001
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# -----------------------------
# Optional Azure integration
# -----------------------------
# AZURE_AD_CLIENT_SECRET=
# AZURE_APIM_SUBSCRIPTION_KEY=

# -----------------------------
# Optional graph backend
# -----------------------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
