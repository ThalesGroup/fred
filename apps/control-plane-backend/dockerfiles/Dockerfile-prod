# -----------------------------------------------------------------------------
# BUILD STAGE
# -----------------------------------------------------------------------------
FROM mirror.gcr.io/python:3.12.13-slim AS builder

ARG USER_NAME=fred-user
ARG USER_ID=1000
ARG GROUP_ID=1000

RUN apt-get update && \
    apt-get install -y --no-install-recommends curl make && \
    rm -rf /var/lib/apt/lists/*

ENV UV_PROJECT_ENVIRONMENT=/app/venv
ENV PATH="/app/venv/bin:$PATH"

WORKDIR /workspace/apps/control-plane-backend

COPY apps/control-plane-backend/Makefile ./
COPY apps/control-plane-backend/pyproject.toml apps/control-plane-backend/uv.lock* ./
COPY apps/control-plane-backend/README.md ./
COPY apps/control-plane-backend/control_plane_backend ./control_plane_backend
COPY scripts/makefiles /workspace/scripts/makefiles
COPY libs/fred-core /workspace/libs/fred-core
COPY libs/fred-sdk /workspace/libs/fred-sdk

RUN make dev VENV=/app/venv TARGET=/app/target

# -----------------------------------------------------------------------------
# FINAL STAGE
# -----------------------------------------------------------------------------
FROM mirror.gcr.io/python:3.12.13-slim

ARG USER_NAME=fred-user
ARG USER_ID=1000
ARG GROUP_ID=1000
ARG PRODUCTION_FASTAPI_DOCS_ENABLED=false

RUN groupadd -g ${GROUP_ID} ${USER_NAME} && \
    useradd -u ${USER_ID} -g ${GROUP_ID} -m ${USER_NAME}

COPY --from=builder --chown=${USER_ID}:${GROUP_ID} /app/venv /app/venv
ENV PATH="/app/venv/bin:$PATH"
ENV PRODUCTION_FASTAPI_DOCS_ENABLED=${PRODUCTION_FASTAPI_DOCS_ENABLED}

WORKDIR /app

# `make dev` installs the local projects in editable mode, so the runtime image
# must keep the same source roots available under `/workspace/...`.
COPY --chown=${USER_ID}:${GROUP_ID} apps/control-plane-backend/pyproject.toml /workspace/apps/control-plane-backend/pyproject.toml
COPY --chown=${USER_ID}:${GROUP_ID} apps/control-plane-backend/README.md /workspace/apps/control-plane-backend/README.md
COPY --chown=${USER_ID}:${GROUP_ID} apps/control-plane-backend/control_plane_backend /workspace/apps/control-plane-backend/control_plane_backend
COPY --chown=${USER_ID}:${GROUP_ID} libs/fred-core /workspace/libs/fred-core
COPY --chown=${USER_ID}:${GROUP_ID} libs/fred-sdk /workspace/libs/fred-sdk

# Remove the broken alembic.ini symlink before copying the real file —
# Kaniko preserves symlinks as-is and would fail resolving the target.
COPY --chown=${USER_ID}:${GROUP_ID} apps/control-plane-backend/. /app/
RUN rm -f /app/alembic.ini
COPY --chown=${USER_ID}:${GROUP_ID} alembic.ini /app/alembic.ini

USER ${USER_NAME}

EXPOSE 8222

ENTRYPOINT ["uvicorn", "control_plane_backend.main:create_app", "--factory"]
CMD ["--port", "8222", "--host", "0.0.0.0", "--log-level", "info", "--loop", "asyncio"]
