# -----------------------------------------------------------------------------
# BUILD STAGE
# -----------------------------------------------------------------------------
FROM mirror.gcr.io/python:3.12.8-slim AS builder
ARG USER_NAME=fred-user
ARG USER_ID=1000
ARG GROUP_ID=1000
ARG UV_VERSION=0.7.21

# Install system deps required for build
RUN apt-get update && \
    apt-get install -y git curl make && \
    rm -rf /var/lib/apt/lists/*

# Install uv globally
RUN curl -LsSf https://astral.sh/uv/${UV_VERSION}/install.sh | sh && \
    mv /root/.local/bin/uv /usr/local/bin/uv && \
    chmod +x /usr/local/bin/uv

# Create virtualenv manually (outside project for portability)
ENV UV_PROJECT_ENVIRONMENT=/app/venv
ENV PATH="/app/venv/bin:$PATH"
ENV TIKTOKEN_CACHE_DIR=/app/encodings

WORKDIR /workspace/apps/knowledge-flow-backend

# Copy python dependency files and Makefile
COPY apps/knowledge-flow-backend/pyproject.toml apps/knowledge-flow-backend/uv.lock* ./
COPY apps/knowledge-flow-backend/Makefile ./

# Copy shared scripts and local lib dependency
COPY scripts /workspace/scripts
COPY libs/fred-core /workspace/libs/fred-core

# Install dependencies using make
RUN make dev VENV=/app/venv TARGET=/app/target
RUN python /workspace/scripts/patch_docling_rapidocr_openvino.py

# Prepare local encodings directory
RUN mkdir -p $TIKTOKEN_CACHE_DIR

# Download encodings for offline usage
RUN python /workspace/scripts/download_encodings.py https://openaipublic.blob.core.windows.net/encodings/cl100k_base.tiktoken

# -----------------------------------------------------------------------------
# FINAL STAGE: PROD IMAGE
# -----------------------------------------------------------------------------
FROM mirror.gcr.io/python:3.12.8-slim
ARG USER_NAME=fred-user
ARG USER_ID=1000
ARG GROUP_ID=1000
ARG HF_OFFLINE_STRICT=1
ARG PRODUCTION_FASTAPI_DOCS_ENABLED=false

# System deps (minimal)
RUN apt-get update && \
    apt-get install -y \
    curl \
    pandoc \
    inkscape \
    libgl1 \
    libmagic1 \
    ffmpeg \
    libreoffice \
    --no-install-recommends && \
    rm -rf /var/lib/apt/lists/*

# Create user
RUN groupadd -g ${GROUP_ID} ${USER_NAME} && \
    useradd -u ${USER_ID} -g ${GROUP_ID} -m ${USER_NAME} && \
    mkdir -p /home/${USER_NAME}/.fred/knowledge-flow && \
    chown -R ${USER_NAME}: /home/${USER_NAME}

# Copy virtualenv and encodings from build stage
COPY --from=builder --chown=${USER_ID}:${GROUP_ID} /app/venv /app/venv
COPY --from=builder --chown=${USER_ID}:${GROUP_ID} /app/encodings /app/encodings

ENV PATH="/app/venv/bin:$PATH"
ENV HOME=/home/${USER_NAME}
ENV TIKTOKEN_CACHE_DIR=/app/encodings
ENV DOCLING_ARTIFACTS_PATH=/app/docling-artifacts
ENV PADDLE_MODELS_DIR=/app/models
ENV PRODUCTION_FASTAPI_DOCS_ENABLED=${PRODUCTION_FASTAPI_DOCS_ENABLED}
ENV DUCKDB_EXTENSION_DIRECTORY=${HOME}/.duckdb/extensions

# Hugging Face / reranker cache layout
ENV CACHE_HOME=/home/${USER_NAME}/.cache
ENV RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-12-v2
ENV RERANKER_MODEL_CACHE=${CACHE_HOME}/huggingface/hub
ENV HF_HOME=${CACHE_HOME}
ENV HF_HUB_CACHE=${RERANKER_MODEL_CACHE}
ENV HUGGINGFACE_HUB_CACHE=${RERANKER_MODEL_CACHE}
ENV SENTENCE_TRANSFORMERS_HOME=${RERANKER_MODEL_CACHE}
ENV TRANSFORMERS_CACHE=${RERANKER_MODEL_CACHE}
RUN mkdir -p ${CACHE_HOME} ${RERANKER_MODEL_CACHE} ${DOCLING_ARTIFACTS_PATH} ${PADDLE_MODELS_DIR} && \
    chown -R ${USER_ID}:${GROUP_ID} ${CACHE_HOME} ${DOCLING_ARTIFACTS_PATH} ${PADDLE_MODELS_DIR}

# Warm caches during build (faster startup, offline-friendly runtime)
USER ${USER_NAME}
RUN mkdir -p ${DUCKDB_EXTENSION_DIRECTORY}
RUN python -c "\
import duckdb; \
con = duckdb.connect(database=':memory:'); \
con.execute('INSTALL httpfs'); \
con.execute('LOAD httpfs')"
RUN python -c "\
from sentence_transformers import CrossEncoder; \
import os; \
CrossEncoder(model_name_or_path=os.environ['RERANKER_MODEL'], cache_folder=os.environ['RERANKER_MODEL_CACHE'])"

# Preload Docling artifacts (layout/table + RapidOCR) for offline-friendly runtime
RUN python -c "\
from pathlib import Path; \
import os; \
from docling.utils.model_downloader import download_models; \
download_models( \
output_dir=Path(os.environ['DOCLING_ARTIFACTS_PATH']), \
progress=False, \
with_layout=True, \
with_tableformer=True, \
with_rapidocr=True, \
with_code_formula=False, \
with_picture_classifier=False, \
with_smolvlm=False, \
with_smoldocling=False, \
with_smoldocling_mlx=False, \
with_granite_vision=False \
)"

# Preload PaddleOCR models (PP-OCRv5) for offline-friendly runtime
RUN python /scripts/download_models.py --models-dir ${PADDLE_MODELS_DIR}

# Runtime offline policy for Hugging Face based dependencies.
ENV HF_HUB_OFFLINE=${HF_OFFLINE_STRICT}
ENV TRANSFORMERS_OFFLINE=${HF_OFFLINE_STRICT}
ENV HF_HUB_DISABLE_TELEMETRY=1

# Set working directory
WORKDIR /app

# `make dev` installs local projects in editable mode, so the runtime image
# must keep the same source roots available under /workspace/...
COPY --chown=${USER_ID}:${GROUP_ID} apps/knowledge-flow-backend/pyproject.toml /workspace/apps/knowledge-flow-backend/pyproject.toml
COPY --chown=${USER_ID}:${GROUP_ID} libs/fred-core /workspace/libs/fred-core
COPY --chown=${USER_ID}:${GROUP_ID} scripts /workspace/scripts

# Remove the broken alembic.ini symlink before copying the real file —
# Kaniko preserves symlinks as-is and would fail resolving the target.
COPY --chown=${USER_ID}:${GROUP_ID} apps/knowledge-flow-backend/. /app/
RUN rm -f /app/alembic.ini
COPY --chown=${USER_ID}:${GROUP_ID} alembic.ini /app/alembic.ini

# Set environment
ENV PYTHONPATH=/app

# Expose Fast API port
EXPOSE 8111

# Entrypoint without make
ENTRYPOINT ["uvicorn", "knowledge_flow_backend.main:create_app", "--factory"]
CMD ["--port", "8111", "--host", "0.0.0.0", "--log-level", "info", "--loop", "asyncio"]
