model
  schema 1.1

type user

type organization
  relations
    # AUTHZ-05 target roles (RFC FRED-AUTHORIZATION-TARGET-MODEL). Stored tuples
    # only — never derived from Keycloak roles or groups. Granted via the
    # config-seeded bootstrap (RFC §24.3) or explicit admin action.
    define platform_admin: [user]
    define platform_observer: [user] or platform_admin

  # AUTHZ-05 (RFC §28): team creation is a one-shot, platform-admin-gated
  # bootstrap action (`POST /teams`), not a team relation. `platform_admin`
  # gains no ongoing relation on the created team from this capability alone.
  define can_create_team: platform_admin

  # AUTHZ-05 review item 9 (RFC Part 6 §32): team-registry governance
  # capabilities. Distinct from §2.2's central rule: these let platform_admin
  # govern the *existence* of teams (the registry) — they grant nothing about
  # a team's agents, prompts, conversations, or resources, which remain
  # governed exclusively by team relations as everywhere else in this schema.
  define can_list_all_teams: platform_admin
  define can_delete_team: platform_admin
  define can_rescue_team_admin: platform_admin

  # AUTHZ-05 review item 8a (RFC Part 6 §29-32): the legacy Keycloak
  # `admin`/`editor`/`viewer` bridge is removed. Admin-tier capabilities
  # (already `admin or platform_admin`) are cut to `platform_admin` alone —
  # same precedent as `can_create_team` (item 5). The "any connected user"
  # tier (`can_read_content`, `can_process_content`, `can_create_agent`,
  # `can_read_kpi`, `can_read_logs`, `can_read_metrics`, `can_read_opensearch`)
  # never protected anything specific — it is removed outright, not replaced
  # by another relation; call sites rely on authentication alone.
  define can_edit_agent_class_path: platform_admin

  # RFC FRED-AUTHORIZATION-TARGET-MODEL §6.1: the platform_observer role's own
  # named capability — cross-user / platform-wide KPI observation, gating both
  # the standalone KPI dashboard (`/monitoring/kpis`) and the control-plane
  # Analytics preset endpoints (`/admin/analytics`). AUTHZ-05 review item 16:
  # previously split into a second, platform_admin-only `can_read_kpi_global`
  # (legacy Action.READ_GLOBAL) for the Analytics presets — retired as a
  # duplicate this RFC never asked for; `platform_admin` already reaches this
  # relation through the `platform_observer` union above. Today both roles see
  # the same platform-wide recap; when Analytics grows admin-only technical
  # panels, gate those specific widgets on a new, narrower capability instead
  # of reintroducing this split.
  define can_observe_platform: platform_observer

  # Platform administration surfaces (global, no resource instance).
  define can_administer_users: platform_admin
  define can_manage_platform: platform_admin
  define can_run_benchmark: platform_admin


type team
  relations
    define organization: [organization]

    # AUTHZ-05 (RFC §26): renamed from owner/manager/member to team_admin/
    # team_editor/team_member, plus a new team_analyst role. team_admin and
    # team_editor are orthogonal, not hierarchical (REBAC.md "hard cross-write
    # rule") — team_admin has full governance authority and zero agent/prompt
    # authority; team_editor is the reverse. team_analyst is a distinct,
    # narrower role for evaluation work (RFC §3.2). None of these relations
    # are ever derived from a platform role (RFC §24.2, §24.7): a
    # `platform_admin from organization` exception was tried for team
    # bootstrap and reverted the same day — OpenFGA cannot express "only if
    # this team has no owner yet", so it applied to every team, always, and
    # was a live escalation through the `add_team_member`/`update_team_member`
    # endpoints. The first `team_admin` of a team is instead granted by a
    # one-shot, platform-admin-gated bootstrap action outside this schema
    # (RFC §28, `POST /teams`), never by a standing relation grant here.
    define team_admin: [user]
    define team_editor: [user]
    define team_analyst: [user]
    define team_member: [user] or team_admin or team_editor or team_analyst

    # Public visibility - allows anyone to read team info. Profile/discovery
    # only: `public` is wired into `can_read` alone, never into any
    # data/agent/prompt/conversation capability.
    define public: [user:*]

    # --------------- Permissions (computed relations) ---------------
    # Can read team info (name, description, banner, admins list...)
    # -> must be at least member or team is public
    define can_read: team_member or public

    # Can update team info (description, banner...)
    # -> must be at least team_admin
    define can_update_info: team_admin

    # Can manage members: add/remove/change role of members depending on their current role
    # To give a given role to a user, you must be able to administer it.
    # All administer_* capabilities are team_admin-only, with no platform-role
    # exception of any kind (see relation comment above for why).
    define can_administer_members: team_admin
    define can_administer_editors: team_admin
    define can_administer_analysts: team_admin
    define can_administer_admins: team_admin

    # Can list all team members with their role
    # -> must be member
    define can_read_members: team_member

    # Can list own conversations within the team
    # -> must be member (public visibility does not grant access to conversations)
    define can_read_conversations: team_member

    # Can see/use the team's agents (templates + managed instances)
    # -> must be member; deliberately excludes `public` (unlike can_read)
    define can_use_team_agents: team_member

    # Team-scoped evaluation capabilities (RFC §6.2/§3.2). team_admin may run
    # evaluations directly (RFC §24.6: team_admin may also grant team_analyst
    # without separate platform approval); team_editor has no evaluation
    # authority by default.
    define can_run_evaluations: team_analyst or team_admin
    define can_manage_evaluation_corpus: team_analyst or team_admin
    define can_read_conversations_for_evaluation: team_analyst

    # --------------- Helpers (not permission to use directly, only to help define them) ---------------

    # Can upload/rename/delete team resources (file/folders)
    # -> must be at least team_editor
    define can_update_resources: team_editor

    # Can create/update/delete team agents
    # -> must be at least team_editor
    define can_update_agents: team_editor

type agent
  relations
    define owner: [user, team]

    # --------------- Permissions (computed relations) ---------------
    # Can read agemt: see its name, description...
    # -> must be at least viewer or team member
    define read: owner or team_member from owner

    # Can update agent configuration
    # -> must be owner
    define update: owner or can_update_agents from owner

    # Can delete agent
    # -> must be owner
    define delete: owner or can_update_agents from owner

type tag
  relations
    define owner: [user, team]
    define editor: [user, team]
    define viewer: [user, team]
    define parent: [tag]

    # --------------- Permissions (computed relations) ---------------
    # Can read tag: see its name, description, list documents...
    # -> must be at least viewer or team member
    define read: viewer or editor or owner or read from parent or team_member from owner

    # Can update tag: change its name, description... add or remove content (like documents) in the tag
    # -> must be at least editor or team_editor
    define update: editor or owner or update from parent or can_update_resources from owner

    # Can delete tag
    # -> must be owner or team_editor
    define delete: owner or delete from parent or can_update_resources from owner

    # Can share tag: add/remove editors/viewers
    # -> must be direct owner (no sharing for team owned tag)
    define share: owner or share from parent

type document
  relations
    define parent: [tag]

    # --------------- Permissions (computed relations) ---------------
    # Can read document: see its content
    # -> must be able to read parent tag (at least viewer)
    define read: read from parent

    # Can update document: change its name, content...
    # -> must be able to manage parent tag (at least editor)
    define update: update from parent

    # Can delete document
    # -> must be able to manage parent tag (at least editor)
    define delete: update from parent

    # Can process document: for RAG or SQL data extraction
    # -> must be able to manage parent tag (at least editor)
    define process: update from parent


type resource
  relations
    define parent: [tag]

    # --------------- Permissions (computed relations) ---------------
    # Can read resources: see its content
    # -> must be able to read parent tag (at least viewer)
    define read: read from parent

    # Can update resources: change its name, content...
    # -> must be able to manage parent tag (at least editor)
    define update: update from parent

    # Can delete resources
    # -> must be able to manage parent tag (at least editor)
    define delete: update from parent

    # Can share resources: add/remove editors/viewers
    # -> must be able to share parent tag
    define share: share from parent
